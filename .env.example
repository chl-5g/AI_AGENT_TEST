# ========== 对话：DeepSeek ==========
OPENAI_API_KEY=sk-你的DeepSeekKey
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_CHAT_MODEL=deepseek-chat

# ========== 向量嵌入：OpenRouter（推荐混搭）==========
# 文档：https://openrouter.ai/docs/api-reference/embeddings
OPENROUTER_API_KEY=sk-or-v1-你的OpenRouterKey
# 可选；不设则默认 https://openrouter.ai/api/v1
# OPENROUTER_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# 嵌入模型（OpenRouter 上多为 厂商/模型 形式）：
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# 也可只设下面这一行，与上一行二选一：
# OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
#
# 可选：OpenRouter 建议在请求头里带来源站点（排名用），本地可填 http://127.0.0.1:8000
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000
# OPENROUTER_X_TITLE=ai_agent_test

# ---------- 其它嵌入方式（不配 OPENROUTER_API_KEY 时才会走）----------
# 仅 OpenAI 官方嵌入：OPENAI_EMBEDDING_API_KEY=sk-proj-...
# 或显式：OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# ---------- HTTP（可选）----------
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:3000

# ---------- 调试（可选）----------
# 设为 1 / true / yes：问答时在 stderr 打印检索到的文档片段（bot.py）
# RAG_DEBUG=1
# 检索条数（默认 5）；总答「未找到」时可试 8～12
# RAG_TOP_K=8

# ---------- 入库与切片（可选，见 script/config.py）----------
# CHUNK_CHARS=400
# CHUNK_OVERLAP=50
# CHROMA_ADD_BATCH_SIZE=256
# Chroma 集合名（默认 support_docs）
# CHROMA_COLLECTION_NAME=support_docs
# 多文件解析线程数（PDF/Docx 多时可调大，默认 4）
# INGEST_IO_WORKERS=4
# 知识库目录（默认 data/；可写绝对路径）
# RAG_KB_DIR=data
